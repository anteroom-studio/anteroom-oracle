# ================================================================
# ZAI ORACLE — ENVIRONMENT VARIABLES
# by Zawwar (github.com/Zawwarsami16)
#
# HOW TO USE:
# 1. Copy this file: cp .env.example .env
# 2. Fill in your keys below
# 3. Never commit .env to GitHub (already in .gitignore)
#
# WHICH KEYS DO YOU ACTUALLY NEED?
# - GROQ_KEY is the only required one (free at groq.com)
# - Everything else is optional — system works without them
# - More keys = more data = better predictions
# ================================================================

# ----------------------------------------------------------------
# AI PROVIDERS — system picks best available automatically
# Priority: Groq → Gemini → Claude → Ollama → Rule-based
# ----------------------------------------------------------------

# Groq — FREE, fastest, best for this system
# Get it: groq.com → sign up → API Keys → Create
GROQ_KEY=

# Google Gemini — FREE tier (15 req/min)
# Get it: aistudio.google.com/app/api-keys
GEMINI_KEY=

# Anthropic Claude — paid but most accurate
# Get it: console.anthropic.com → API Keys
ANTHROPIC_KEY=

# ----------------------------------------------------------------
# DATA PROVIDERS
# ----------------------------------------------------------------

# Etherscan — Ethereum whale wallet tracking
# Get it: etherscan.io/apis → Create API Key (free)
ETHERSCAN_KEY=

# ----------------------------------------------------------------
# OPTIONAL — system works fine without these
# ----------------------------------------------------------------

# Telegram bot — get alerts on your phone when something big happens
# Get it: talk to @BotFather on Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
